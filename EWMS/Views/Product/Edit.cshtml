@model EWMS.ViewModels.EditProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <h1>Edit Product</h1>
    <p>Update product information</p>
</div>

<div style="display: flex; gap: 12px; margin-bottom: 22px;">
    <a asp-action="Details" asp-route-id="@Model.ProductId" class="btn btn-outline btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Details
    </a>
    <a asp-action="Index" class="btn btn-outline btn-sm">
        <i class="bi bi-list"></i> Back to List
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h5>
            <i class="bi bi-pencil-square" style="color: var(--warning);"></i>
            Edit Product Information
        </h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProductId" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-grid">
                <!-- Product Name -->
                <div class="form-group full">
                    <label asp-for="ProductName"></label>
                    <input asp-for="ProductName" class="form-control" placeholder="e.g. Dell XPS 15 9530 Laptop" required />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <!-- Category -->
                <div class="form-group full">
                    <label asp-for="CategoryId">Category</label>
                    <div style="display: flex; gap: 8px;">
                        <select asp-for="CategoryId" class="form-control" id="CategoryId" onchange="toggleCategoryInput()">
                            <option value="">— Select Category —</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.CategoryId">@category.CategoryName</option>
                            }
                        </select>
                        <button type="button" class="btn btn-primary" onclick="showNewCategoryInput()" id="btnAddCategory" title="Add new category">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>

                <!-- New Category Input (hidden by default) -->
                <div class="form-group full" id="newCategoryGroup" style="display: none;">
                    <label asp-for="NewCategoryName">New Category Name</label>
                    <div style="display: flex; gap: 8px;">
                        <input asp-for="NewCategoryName" class="form-control" id="NewCategoryName" placeholder="Enter new category name" />
                        <button type="button" class="btn btn-outline-secondary" onclick="hideNewCategoryInput()" title="Cancel">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>

                <!-- Supplier -->
                <div class="form-group full">
                    <label asp-for="SupplierId">Supplier</label>
                    <div style="display: flex; gap: 8px;">
                        <select asp-for="SupplierId" class="form-control" id="SupplierId" onchange="toggleSupplierInput()">
                            <option value="">— Select Supplier —</option>
                            @foreach (var supplier in Model.Suppliers)
                            {
                                <option value="@supplier.SupplierId">@supplier.SupplierName</option>
                            }
                        </select>
                        <button type="button" class="btn btn-primary" onclick="showNewSupplierInput()" id="btnAddSupplier" title="Add new supplier">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>

                <!-- New Supplier Input (hidden by default) -->
                <div class="form-group full" id="newSupplierGroup" style="display: none;">
                    <label asp-for="NewSupplierName">New Supplier Name</label>
                    <div style="display: flex; gap: 8px;">
                        <input asp-for="NewSupplierName" class="form-control" id="NewSupplierName" placeholder="Enter new supplier name" />
                        <button type="button" class="btn btn-outline-secondary" onclick="hideNewSupplierInput()" title="Cancel">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>

                <!-- Unit -->
                <div class="form-group full">
                    <label asp-for="Unit">Unit</label>
                    <div style="display: flex; gap: 8px;">
                        <select asp-for="Unit" class="form-control" id="Unit" onchange="toggleUnitInput()">
                            <option value="">— Select Unit —</option>
                            @foreach (var unit in Model.Units)
                            {
                                <option value="@unit">@unit</option>
                            }
                        </select>
                        <button type="button" class="btn btn-primary" onclick="showNewUnitInput()" id="btnAddUnit" title="Add new unit">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>

                <!-- New Unit Input (hidden by default) -->
                <div class="form-group full" id="newUnitGroup" style="display: none;">
                    <label asp-for="NewUnit">New Unit</label>
                    <div style="display: flex; gap: 8px;">
                        <input asp-for="NewUnit" class="form-control" id="NewUnit" placeholder="Enter new unit" />
                        <button type="button" class="btn btn-outline-secondary" onclick="hideNewUnitInput()" title="Cancel">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>

            </div>

            <hr class="section-divider" />

            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <a asp-action="Details" asp-route-id="@Model.ProductId" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Edit Product
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function showNewCategoryInput() {
            document.getElementById('CategoryId').value = '';
            document.getElementById('CategoryId').disabled = true;
            document.getElementById('btnAddCategory').style.display = 'none';
            document.getElementById('newCategoryGroup').style.display = 'block';
            document.getElementById('NewCategoryName').focus();
        }

        function hideNewCategoryInput() {
            document.getElementById('CategoryId').disabled = false;
            document.getElementById('btnAddCategory').style.display = 'block';
            document.getElementById('newCategoryGroup').style.display = 'none';
            document.getElementById('NewCategoryName').value = '';
        }

        function toggleCategoryInput() {
            if (document.getElementById('CategoryId').value) {
                hideNewCategoryInput();
            }
        }

        function showNewSupplierInput() {
            document.getElementById('SupplierId').value = '';
            document.getElementById('SupplierId').disabled = true;
            document.getElementById('btnAddSupplier').style.display = 'none';
            document.getElementById('newSupplierGroup').style.display = 'block';
            document.getElementById('NewSupplierName').focus();
        }

        function hideNewSupplierInput() {
            document.getElementById('SupplierId').disabled = false;
            document.getElementById('btnAddSupplier').style.display = 'block';
            document.getElementById('newSupplierGroup').style.display = 'none';
            document.getElementById('NewSupplierName').value = '';
        }

        function toggleSupplierInput() {
            if (document.getElementById('SupplierId').value) {
                hideNewSupplierInput();
            }
        }

        function showNewUnitInput() {
            document.getElementById('Unit').value = '';
            document.getElementById('Unit').disabled = true;
            document.getElementById('btnAddUnit').style.display = 'none';
            document.getElementById('newUnitGroup').style.display = 'block';
            document.getElementById('NewUnit').focus();
        }

        function hideNewUnitInput() {
            document.getElementById('Unit').disabled = false;
            document.getElementById('btnAddUnit').style.display = 'block';
            document.getElementById('newUnitGroup').style.display = 'none';
            document.getElementById('NewUnit').value = '';
        }

        function toggleUnitInput() {
            if (document.getElementById('Unit').value) {
                hideNewUnitInput();
            }
        }
    </script>
}
