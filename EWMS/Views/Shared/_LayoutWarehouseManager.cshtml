@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EWMS Warehouse Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --navy: #2c3e50;
            --blue: #3498db;
            --green: #27ae60;
            --red: #e74c3c;
            --orange: #e67e22;
            --purple: #9b59b6;
            --yellow: #f39c12;
            --gray: #95a5a6;
            --dark: #34495e;
            --light: #ecf0f1;
            --white: #ffffff;
            --border: #dfe6e9;
            --shadow: rgba(0, 0, 0, 0.1);
            --text: #2c3e50;
            --text-muted: #7f8c8d;
            --bg: #f8f9fa;
            --success: #27ae60;
            --danger: #e74c3c;
            --warning: #f39c12;
            --info: #3498db;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: var(--bg);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            font-size: 14px;
            color: var(--text);
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 260px;
            background: var(--navy);
            color: white;
            padding: 0;
            z-index: 1000;
            overflow-y: auto;
            box-shadow: 2px 0 8px var(--shadow);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 24px 20px;
            background: var(--dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

            .sidebar-header h3 {
                margin: 0;
                font-size: 1.3rem;
                font-weight: 700;
                color: #fff;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .sidebar-header small {
                color: rgba(255,255,255,0.6);
                font-size: 0.75rem;
                display: block;
                margin-top: 4px;
            }

        .nav-section {
            padding: 16px 20px 8px;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        .sidebar-menu {
            padding: 0;
            list-style: none;
        }

        .sidebar-menu-item {
            padding: 12px 20px;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
            border-left: 3px solid transparent;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 500;
        }

            .sidebar-menu-item:hover {
                background: rgba(255,255,255,0.08);
                color: white;
                border-left-color: var(--blue);
                text-decoration: none;
            }

            .sidebar-menu-item.active {
                background: rgba(255,255,255,0.12);
                color: white;
                border-left-color: var(--blue);
            }

            .sidebar-menu-item i.menu-icon {
                font-size: 1.1rem;
                width: 24px;
                text-align: center;
            }

        .sidebar-menu {
            flex: 1;
            overflow-y: auto;
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 20px;
            background: rgba(0,0,0,0.15);
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4299e1 0%, #2c5282 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 0.88rem;
            font-weight: 700;
            color: #fff;
        }

        .user-role {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.5);
        }

        .logout-btn {
            margin-top: 12px;
            width: 100%;
            padding: 8px;
            border-radius: 8px;
            cursor: pointer;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.72);
            font-size: 0.8rem;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: all 0.2s;
        }

            .logout-btn:hover {
                background: rgba(255,255,255,0.15);
                color: #fff;
            }

        .main-content {
            margin-left: 260px;
            padding: 24px 32px;
            min-height: 100vh;
        }

        .page-header {
            margin-bottom: 24px;
        }

        .page-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--navy);
            margin: 0 0 4px 0;
        }

        .page-header p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin: 0;
        }

        @@media (max-width: 768px) {
            .sidebar {
                width: 0;
                overflow: hidden;
            }

                .sidebar.show {
                    width: 260px;
                }

            .main-content {
                margin-left: 0;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar for Warehouse Manager -->
    <div class="sidebar">
        <div class="sidebar-header">
            <h3><i class="bi bi-building"></i> EWMS</h3>
            <small>Warehouse Manager</small>
        </div>

        <div class="sidebar-menu">
            <a href="@Url.Action("Index", "Warehouse")"
               class="sidebar-menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Warehouse" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <div>
                    <i class="bi bi-building menu-icon"></i>
                    <span>Warehouses</span>
                </div>
            </a>
            <a href="@Url.Action("NXT", "Reports")"
               class="sidebar-menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
                <div>
                    <i class="bi bi-clipboard-data menu-icon"></i>
                    <span>NXT Report</span>
                </div>
            </a>
        </div>

        <div class="sidebar-footer">
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div class="user-info">
                    <div class="user-avatar">
                        @(User.FindFirst(ClaimTypes.GivenName)?.Value?.Substring(0, 1).ToUpper() ?? "W")
                    </div>
                    <div>
                        <div class="user-name">@(User.FindFirst(ClaimTypes.GivenName)?.Value ?? User.Identity?.Name)</div>
                        <div class="user-role">@User.FindFirst(ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
                <div class="mt-3">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-grid">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="logout-btn">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="mt-3">
                    <a href="@Url.Action("Login", "Account")" class="btn btn-sm btn-outline-light w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
