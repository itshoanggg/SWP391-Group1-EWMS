@{
    if (User.IsInRole("Purchasing Staff")) { Layout = "~/Views/Shared/_LayoutPurchasingStaff.cshtml"; }
}
@model EWMS.Models.PurchaseOrder

@{
    ViewData["Title"] = "Stock-In Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Inventory/StockInDetails.css" />
}

<div class="container-fluid">
    <!-- Header -->
    <div class="header-section">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <a href="@((ViewBag.ReadOnly == true) ? Url.Action("History", "StockIn") : Url.Action("Index", "StockIn"))" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
                <div>
                    <h2 class="mb-0">Stock-In Details</h2>
                    <small class="text-muted">Confirm actual goods received for purchase order PO-@Model.PurchaseOrderId</small>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-secondary" onclick="window.print()">
                    <i class="fas fa-print"></i> Print SKU Labels
                </button>
                @if (ViewBag.ReadOnly != true)
                {
                    <button class="btn btn-success" id="btn-confirm" onclick="confirmStockIn()">
                        <i class="fas fa-check-circle"></i> Confirm Stock-In
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- PO Information -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card info-card">
                <div class="card-header">
                    <i class="fas fa-file-invoice"></i> PO Information
                </div>
                <div class="card-body">
                    <div class="info-row">
                        <span class="label">Order Number:</span>
                        <span class="value" id="po-number">PO-@Model.PurchaseOrderId</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Order Date:</span>
                        <span class="value" id="po-date">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Person in Charge:</span>
                        <span class="value" id="po-creator">@(Model.CreatedByNavigation.FullName ?? Model.CreatedByNavigation.Username)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card info-card">
                <div class="card-header">
                    <i class="fas fa-truck"></i> Supplier
                </div>
                <div class="card-body">
                    <div class="info-row">
                        <span class="label">Name:</span>
                        <span class="value" id="supplier-name">@Model.Supplier.SupplierName</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Supplier Code:</span>
                        <span class="value" id="supplier-code">NCC-@Model.Supplier.SupplierId</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Phone:</span>
                        <span class="value" id="supplier-phone">@Model.Supplier.Phone</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card">
        <div class="card-header">
            <i class="fas fa-boxes"></i> Product List
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="products-table">
                    <thead>
                        <tr>
                            <th style="width: 10%">SKU</th>
                            <th style="width: 25%">PRODUCT NAME</th>
                            <th style="width: 10%">ORDER QTY</th>
                            <th style="width: 10%">ACTUAL RECEIVED</th>
                            <th style="width: 35%">STORAGE LOCATION</th>
                            
                        </tr>
                    </thead>
                    <tbody id="products-tbody">
                        <tr>
                            <td colspan="5" class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <div class="row">
                <div class="col-md-6">
                    <div class="summary-item">
                        <span>Total SKUs:</span>
                        <strong id="total-sku">0</strong>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="summary-item">
                        <span>Total Ordered Qty:</span>
                        <strong id="total-ordered">0</strong>
                    </div>
                    <div class="summary-item">
                        <span>Total Actual Received:</span>
                        <strong id="total-received" class="text-primary">0</strong>
                    </div>
                    <div class="summary-item">
                        <span>Status:</span>
                        <strong id="receipt-status" class="text-warning">Missing 5 items</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Alert Modal -->
<div class="modal fade" id="alertModal" tabindex="-1" aria-labelledby="alertModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" id="alertModalHeader">
                <h5 class="modal-title" id="alertModalLabel">
                    <i class="fas fa-info-circle me-2" id="alertModalIcon"></i>
                    <span id="alertModalTitle">Notification</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="alertModalBody">
                <!-- Message will be inserted here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="confirmModalLabel">
                    <i class="fas fa-question-circle me-2"></i>
                    Confirmation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="confirmModalBody">
                <!-- Message will be inserted here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmModalOkBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        const purchaseOrderId = @Model.PurchaseOrderId;
        window.readOnlyMode = @(ViewBag.ReadOnly == true ? "true" : "false");
        const warehouseId = @ViewBag.WarehouseId;
        const userId = @ViewBag.UserId;

        console.log('🔍 Variables check:', {
            purchaseOrderId: purchaseOrderId,
            warehouseId: warehouseId,
            userId: userId
        });
    </script>
    <script src="~/js/Inventory/StockInDetails.js"></script>
}
