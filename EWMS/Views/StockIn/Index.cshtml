@{
    if (User.IsInRole("Purchasing Staff")) { Layout = "~/Views/Shared/_LayoutPurchasingStaff.cshtml"; }

    ViewData["Title"] = "Stock-In Management";
    var warehouseId = ViewBag.WarehouseId;
    var pendingTransfers = ViewBag.PendingTransferStockIns as List<EWMS.ViewModels.PendingTransferReceiptViewModel>
        ?? new List<EWMS.ViewModels.PendingTransferReceiptViewModel>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/Inventory/StockIn.css" />
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-warehouse"></i> Stock-In Management</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Main Card with Tabs -->
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="mb-0">Pending Orders</h3>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-primary active" id="btnPurchaseOrders" onclick="showPurchaseOrders()">
                        <i class="bi bi-cart"></i> Purchase Orders
                    </button>
                    <button type="button" class="btn btn-outline-primary" id="btnTransferOrders" onclick="showTransferOrders()">
                        <i class="bi bi-arrow-left-right"></i> Transfer Orders
                    </button>
                </div>
            </div>
            
            <!-- Filters for Purchase Orders -->
            <div id="purchaseOrderFilters">
                <div class="row g-2">
                    <div class="col-md-3">
                        <label class="form-label small">Status:</label>
                        <select class="form-select" id="filter-status">
                            <option value="">All</option>
                            <option value="Ordered">Ordered</option>
                        <option value="PartiallyReceived">Partially Received</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Search:</label>
                    <input type="text" class="form-control" id="search-input"
                           placeholder="Search by order number or supplier...">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" onclick="loadPurchaseOrders()">
                        <i class="fas fa-sync-alt"></i> Refresh
                    </button>
                </div>
            </div>
        </div>
        
        <div class="card-body">
            <!-- Purchase Orders Section -->
            <div id="purchaseOrdersSection">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h5 class="mb-0">
                        <i class="fas fa-list-ul text-primary"></i> Purchase Order List
                    </h5>
                    <div class="d-flex align-items-center gap-2">
                        <label class="mb-0 text-muted page-size-label">
                            <i class="fas fa-layer-group"></i> Show:
                        </label>
                        <select class="form-select form-select-sm" id="page-size-select" onchange="changePageSize()">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span class="text-muted page-size-label">entries</span>
                    </div>
                </div>
                <div class="table-responsive">
                <table class="table table-hover" id="purchase-orders-table">
                    <thead>
                        <tr>
                            <th width="10%">ORDER NO.</th>
                            <th width="20%">SUPPLIER</th>
                            <th width="12%">EXPECTED DATE</th>
                            <th width="10%" class="text-end">ORDERED QTY</th>
                            <th width="10%" class="text-end">RECEIVED</th>
                            <th width="10%" class="text-end">REMAINING</th>
                            <th width="18%">STATUS</th>
                            <th width="10%">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
                </div>
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-3">
                    <div>
                        <span id="pagination-info" class="d-flex align-items-center gap-2">
                            <i class="fas fa-info-circle text-primary"></i>
                            <span>Showing 0 to 0 of 0 entries</span>
                        </span>
                    </div>
                    <nav aria-label="Table pagination">
                        <div id="pagination-controls">
                            <!-- Pagination will be rendered here by JavaScript -->
                        </div>
                    </nav>
                </div>
            </div>
            
            <!-- Transfer Orders Section -->
            <div id="transferOrdersSection" style="display: none;">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>TRANSFER ID</th>
                                <th>SOURCE WAREHOUSE</th>
                                <th>PRODUCTS</th>
                                <th class="text-end">TOTAL QTY</th>
                                <th>STATUS</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pendingTransfers != null && pendingTransfers.Any())
                            {
                                @foreach (var transfer in pendingTransfers)
                                {
                                    <tr>
                                        <td><strong>TR-@transfer.TransferId.ToString("D4")</strong></td>
                                        <td>@transfer.CounterpartyWarehouseName</td>
                                        <td>@transfer.ProductSummary</td>
                                        <td class="text-end">@transfer.TotalQuantity</td>
                                        <td>
                                            <span class="badge @(transfer.IsProcessed ? "bg-success" : "bg-warning text-dark")">
                                                @(transfer.IsProcessed ? "Processed" : transfer.Status)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1 flex-wrap">
                                                @if (transfer.IsProcessed)
                                                {
                                                    <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Details", "Transfer", new { id = transfer.TransferId })">
                                                        <i class="fas fa-eye"></i> Details
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a class="btn btn-success btn-sm" href="@Url.Action("TransferDetails", new { transferId = transfer.TransferId })">
                                                        <i class="fas fa-box-arrow-in-down"></i> Receive
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-5">
                                        <i class="bi bi-inbox" style="font-size: 48px; opacity: 0.3;"></i>
                                        <p class="mt-2 mb-0">No pending transfer orders</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Modal for Ordered status -->
<div class="modal fade" id="orderedPoModal" tabindex="-1" aria-labelledby="orderedPoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="orderedPoModalLabel"><i class="fas fa-clipboard-list me-2"></i>Purchase Order Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="ordered-po-info" class="mb-3">
                    <!-- Filled by JS: PO number, supplier, expected date, total amount -->
                </div>
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-striped align-middle" id="ordered-po-products">
                        <thead>
                            <tr>
                                <th style="width: 12%">SKU</th>
                                <th style="width: 40%">Product</th>
                                <th class="text-end" style="width: 12%">Qty</th>
                                <th class="text-end" style="width: 18%">Unit Price</th>
                                <th class="text-end" style="width: 18%">Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="5" class="text-center py-3 text-muted">
                                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                                    Loading...
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end">Total:</th>
                                <th class="text-end" id="ordered-po-total">0</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="row g-3 align-items-center">
                    <div class="col-auto">
                        <label for="receipt-date-input" class="col-form-label"><i class="far fa-calendar-alt me-1"></i>Receipt Date</label>
                    </div>
                    <div class="col-auto">
                        <input type="date" class="form-control" id="receipt-date-input" value="@DateTime.Today.ToString("yyyy-MM-dd")" readonly style="background-color: #e9ecef; cursor: not-allowed;" />
                    </div>
                    <div class="col-auto">
                    </div>
                </div>
                <input type="hidden" id="ordered-po-id" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                <a id="btn-proceed-stockin" class="btn btn-primary disabled" role="button" aria-disabled="true" tabindex="-1">
                    <i class="fas fa-box-open me-1"></i> Create Stock In Receipt
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    const warehouseId = @warehouseId;

    if (!warehouseId) {
        console.error('WarehouseId is not defined!');
        alert('Error: Warehouse could not be identified. Please log in again.');
    }
    
    function showPurchaseOrders() {
        document.getElementById('purchaseOrdersSection').style.display = 'block';
        document.getElementById('transferOrdersSection').style.display = 'none';
        document.getElementById('purchaseOrderFilters').style.display = 'block';
        document.getElementById('btnPurchaseOrders').classList.add('active');
        document.getElementById('btnTransferOrders').classList.remove('active');
    }

    function showTransferOrders() {
        document.getElementById('purchaseOrdersSection').style.display = 'none';
        document.getElementById('transferOrdersSection').style.display = 'block';
        document.getElementById('purchaseOrderFilters').style.display = 'none';
        document.getElementById('btnPurchaseOrders').classList.remove('active');
        document.getElementById('btnTransferOrders').classList.add('active');
    }
</script>
<script src="~/js/Inventory/StockIn.js"></script>

