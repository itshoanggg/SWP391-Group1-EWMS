@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const warehouseId = @userWarehouseId;
            let currentProducts = [];

            // Load Racks for source warehouse
            $.get(`/Stock/GetRacks?warehouseId=${warehouseId}`, function (data) {
                if (data && !data.error) {
                    data.forEach(function (r) {
                        $('#fromRack').append(`<option value="${r.rack}">${r.rack}</option>`);
                    });
                }
            });

            // When Rack changes, load Locations
            $('#fromRack').change(function () {
                const rack = $(this).val();
                $('#fromLocation').html('<option value="">-- Select Location --</option>');
                $('#productSelect').html('<option value="">-- Select Source Location First --</option>');
                $('#availableStock').text('Available Quantity: 0');
                $('#qtyInput').removeAttr('max').val('');
                currentProducts = [];

                if (rack) {
                    $.get(`/Stock/GetLocationsByRack?warehouseId=${warehouseId}&rack=${rack}`, function (data) {
                        if (data && !data.error) {
                            data.forEach(function (l) {
                                $('#fromLocation').append(`<option value="${l.locationId}">${l.locationCode} (${l.locationName || 'N/A'})</option>`);
                            });
                        }
                    });
                }
            });

            // When Location changes, load Products
            $('#fromLocation').change(function () {
                const locationId = $(this).val();
                $('#productSelect').html('<option value="">-- Select Product --</option>');
                $('#availableStock').text('Available Quantity: 0');
                $('#qtyInput').removeAttr('max').val('');
                currentProducts = [];

                if (locationId) {
                    $.get(`/Stock/GetProductsByLocation?locationId=${locationId}`, function (data) {
                        if (data && !data.error) {
                            currentProducts = data;
                            data.forEach(function (p) {
                                $('#productSelect').append(`<option value="${p.productId}">${p.sku} - ${p.productName} (Qty: ${p.quantity})</option>`);
                            });
                        }
                    });
                }
            });

            // Update available stock display
            $('#productSelect').change(function () {
                const pId = $(this).val();
                if (pId) {
                    const prod = currentProducts.find(p => p.productId == pId);
                    if (prod) {
                        $('#availableStock').text(`Available Quantity: ${prod.quantity}`);
                        $('#qtyInput').attr('max', prod.quantity);
                    }
                } else {
                    $('#availableStock').text('Available Quantity: 0');
                    $('#qtyInput').removeAttr('max');
                }
            });
        });
    </script>
}
