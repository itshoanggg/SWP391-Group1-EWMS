@{
    var isManager = User.IsInRole("Warehouse Manager");
    var isInventoryStaff = User.IsInRole("Inventory Staff");
    
    if (isManager)
    {
        Layout = "~/Views/Shared/_LayoutWarehouseManager.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    
    ViewData["Title"] = "Create Transfer";
    var warehouses = ViewBag.Warehouses as List<EWMS.Models.Warehouse> ?? new List<EWMS.Models.Warehouse>();
    var userWarehouse = ViewBag.UserWarehouse as EWMS.Models.Warehouse;
    var userWarehouseId = ViewBag.UserWarehouseId ?? 0;
    var fromRacks = ViewBag.FromRacks as List<string> ?? new List<string>();
}

<style>
    .create-header {
        background: linear-gradient(180deg, #2c3e50, #34495e);
        color: white;
        padding: 1.5rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 15px rgba(44, 62, 80, 0.35);
    }
    .create-header h2 {
        margin: 0;
        font-weight: 600;
        font-size: 28px;
    }
    .form-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }
    .form-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
    }
    .form-control:focus, .form-select:focus {
        border-color: #2c3e50;
        box-shadow: 0 0 0 0.2rem rgba(44, 62, 80, 0.25);
    }
    .btn-create {
        background: linear-gradient(180deg, #2c3e50, #34495e);
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(44, 62, 80, 0.35);
        color: white;
    }
    .btn-cancel {
        background: white;
        border: 2px solid #6c757d;
        color: #6c757d;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-cancel:hover {
        background: #6c757d;
        color: white;
    }
</style>

<div class="create-header">
    <h2><i class="bi bi-plus-circle me-2"></i>Create Transfer Request</h2>
    <p class="mb-0 mt-2" style="opacity: 0.9;">Transfer goods from your warehouse. Warehouse manager will select the destination and confirm.</p>
</div>

@if (ViewData.ModelState.ErrorCount > 0)
{
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-circle me-2"></i>
            <strong>Error:</strong> Please check the information.
            <div class="mb-0 mt-2">
            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        </div>
}

