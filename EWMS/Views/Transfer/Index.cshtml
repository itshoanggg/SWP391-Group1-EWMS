@using System.Security.Claims
@model List<EWMS.Models.TransferRequest>
@{
    var isManager = ViewBag.IsManager as bool? ?? false;
    Layout = isManager ? "~/Views/Shared/_LayoutWarehouseManager.cshtml" : "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cross-Warehouse Transfer";
    var userWarehouseId = ViewBag.UserWarehouseId ?? 0;
}

<style>
    .transfer-header {
        background: linear-gradient(180deg, #2c3e50, #34495e);
        color: white;
        padding: 1.5rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 15px rgba(44, 62, 80, 0.35);
    }
    .transfer-header h2 { margin: 0; font-weight: 600; font-size: 28px; }
    .btn-create-transfer {
        background: white;
        color: #2c3e50;
        border: 2px solid white;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        text-decoration: none;
    }
    .btn-create-transfer:hover {
        background: rgba(255, 255, 255, 0.9);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        color: #2c3e50;
        text-decoration: none;
    }
    .transfer-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        overflow: hidden;
    }
    .search-box {
        padding: 12px 15px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
    }
    .search-box:focus {
        border-color: #2c3e50;
        outline: none;
        box-shadow: 0 0 0 3px rgba(44, 62, 80, 0.1);
    }
    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .status-completed { background: #d4edda; color: #155724; }
    .status-approved { background: #d1ecf1; color: #0c5460; }
    .status-rejected { background: #f8d7da; color: #721c24; }
    .status-transit { background: #cce5ff; color: #004085; }
    .status-pending { background: #fff3cd; color: #856404; }
    .btn-details {
        color: #2c3e50;
        font-weight: 600;
        text-decoration: none;
        padding: 6px 16px;
        border-radius: 6px;
        transition: all 0.2s ease;
        border: 1px solid #2c3e50;
        display: inline-block;
    }
    .btn-details:hover {
        background: #2c3e50;
        color: white;
        text-decoration: none;
    }
</style>

<div class="transfer-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-arrow-left-right me-2"></i>Cross-Warehouse Transfer</h2>
        <p class="mb-0 mt-2" style="opacity: 0.9;">@(isManager ? "Create and manage transfers between warehouses" : "View transfers between warehouses")</p>
    </div>
    @if (isManager)
    {
        <a asp-action="Create" class="btn-create-transfer">
            <i class="bi bi-plus-circle me-2"></i>New Transfer
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <input id="transferSearch" type="search" placeholder="Search by code, warehouse, product..." class="search-box w-100" style="max-width: 400px;" />
</div>

<div class="transfer-card">
    <div class="table-responsive">
        <table id="transferTable" class="table table-hover mb-0">
            <thead>
                <tr>
                    <th><i class="bi bi-hash me-1"></i>Code</th>
                    <th><i class="bi bi-box-arrow-right me-1"></i>From</th>
                    <th><i class="bi bi-box-arrow-in-down me-1"></i>To</th>
                    <th><i class="bi bi-boxes me-1"></i>Products</th>
                    <th><i class="bi bi-person me-1"></i>Created By</th>
                    <th><i class="bi bi-calendar me-1"></i>Date</th>
                    <th><i class="bi bi-info-circle me-1"></i>Status</th>
                    <th><i class="bi bi-gear me-1"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var t in Model)
                    {
                        var status = (t.Status ?? "Unknown").ToLowerInvariant();
                        var statusClass = status switch
                        {
                            "completed" => "status-completed",
                            "approved" => "status-approved",
                            "rejected" => "status-rejected",
                            "in transit" => "status-transit",
                            _ => "status-pending"
                        };
                        <tr>
                            <td><strong>TR-@t.TransferId.ToString("D4")</strong></td>
                            <td>@t.FromWarehouse?.WarehouseName</td>
                            <td>@(t.ToWarehouse?.WarehouseName ?? "-")</td>
                            <td>
                                @if (t.TransferDetails != null && t.TransferDetails.Any())
                                {
                                    @string.Join(", ", t.TransferDetails.Select(d => d.Product?.ProductName ?? "?"))
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@(t.RequestedByNavigation?.FullName ?? t.RequestedBy.ToString())</td>
                            <td><small class="text-muted">@t.RequestedDate?.ToString("dd/MM/yyyy HH:mm")</small></td>
                            <td><span class="status-badge @statusClass">@t.Status</span></td>
                            <td>
                                <a class="btn-details" asp-action="Details" asp-route-id="@t.TransferId">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                            <p class="mt-2 mb-0">No transfer requests yet.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById('transferSearch');
            const table = document.getElementById('transferTable');
            if (!input || !table) return;

            input.addEventListener('input', function () {
                const q = this.value.trim().toLowerCase();
                const rows = table.tBodies[0].rows;
                for (let i = 0; i < rows.length; i++) {
                    const rowText = rows[i].innerText.toLowerCase();
                    rows[i].style.display = rowText.indexOf(q) > -1 ? '' : 'none';
                }
            });
        })();
    </script>
}
