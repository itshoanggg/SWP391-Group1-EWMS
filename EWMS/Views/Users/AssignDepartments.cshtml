@model EWMS.ViewModels.AssignDepartmentsViewModel
@{
    ViewData["Title"] = "Assign Departments";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<h2>Assign Departments to @Model.Username</h2>

<form asp-action="AssignDepartments" method="post">
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
    <input type="hidden" asp-for="UserId" />

    <div class="mb-3">
        <label class="form-label">Departments (Warehouses)</label>
        <div style="max-height:300px; overflow:auto; border:1px solid #ddd; padding:10px;">
            @foreach (var w in Model.AvailableWarehouses)
            {
                <div class="form-check">
                    <input class="form-check-input warehouse-checkbox" type="checkbox" name="SelectedWarehouseIds" value="@w.WarehouseId"
                        id="w_@w.WarehouseId" @(Model.SelectedWarehouseIds.Contains(w.WarehouseId) ? "checked" : "") />
                    <label class="form-check-label" for="w_@w.WarehouseId">@w.WarehouseName</label>
                </div>
            }
        </div>
        <span asp-validation-for="SelectedWarehouseIds" class="text-danger small d-block mt-1"></span>
        <small class="text-muted d-block mt-1">Only Admin can assign multiple warehouses. Other roles can only be assigned to 1 warehouse.</small>
    </div>

    <div class="text-end">
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            var isAdmin = @((ViewBag.IsAdmin ?? false).ToString().ToLower());

            function updateWarehouseCheckboxes() {
                if (!isAdmin) {
                    var checkedCount = $('input[name="SelectedWarehouseIds"]:checked').length;

                    if (checkedCount >= 1) {
                        $('input[name="SelectedWarehouseIds"]:not(:checked)').prop('disabled', true);
                    } else {
                        $('input[name="SelectedWarehouseIds"]').prop('disabled', false);
                    }
                }
            }

            $('input[name="SelectedWarehouseIds"]').change(updateWarehouseCheckboxes);

            // Initial run on load
            updateWarehouseCheckboxes();
        });
    </script>
}
