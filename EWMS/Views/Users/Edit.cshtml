@model EWMS.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var roles = ViewBag.Roles as List<EWMS.Models.Role> ?? new();
    var warehouses = ViewBag.Warehouses as List<EWMS.Models.Warehouse> ?? new();
    var selected = Model.WarehouseIds ?? new List<int>();
}

<h2>Edit User</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input asp-for="Username" class="form-control" readonly />
                <input type="hidden" name="Username" value="@Model.Username" />
                <small class="text-muted"><i class="fas fa-lock me-1"></i>Username cannot be changed after creation</small>
            </div>

            <div class="mb-3">
                <label class="form-label">New Password (leave blank to keep)</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Full name</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Role</label>
                <select asp-for="RoleId" class="form-select">
                    <option value="">-- Select role --</option>
                    @foreach (var r in roles)
                    {
                        <option value="@r.RoleId"
                            selected="@(Model.RoleId==r.RoleId? "selected": null)">@r.RoleName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Departments (Warehouses)</label>
                <div style="max-height:220px; overflow:auto; border:1px solid #ddd; padding:8px;">
                    @foreach (var w in warehouses)
                    {
                        <div class="form-check">
                            <input class="form-check-input warehouse-checkbox" type="checkbox" name="WarehouseIds" value="@w.WarehouseId"
                                id="w_@w.WarehouseId" @(selected.Contains(w.WarehouseId) ? "checked" : "") />
                            <label class="form-check-label" for="w_@w.WarehouseId">@w.WarehouseName</label>
                        </div>
                    }
                </div>
                <span asp-validation-for="WarehouseIds" class="text-danger small d-block mt-1"></span>
                <small class="text-muted d-block mt-1">Non-manager roles can only be assigned to 1 warehouse</small>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
    </div>

    <div class="text-end">
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            function updateWarehouseCheckboxes() {
                var selectedRoleId = $('#RoleId').val();
                if (!selectedRoleId) return;

                var selectedRoleText = $('#RoleId option:selected').text();
                var isManager = selectedRoleText === 'Admin' || selectedRoleText === 'Warehouse Manager';

                if (!isManager) {
                    var checkedCount = $('input[name="WarehouseIds"]:checked').length;

                    if (checkedCount >= 1) {
                        $('input[name="WarehouseIds"]:not(:checked)').prop('disabled', true);
                    } else {
                        $('input[name="WarehouseIds"]').prop('disabled', false);
                    }
                } else {
                    $('input[name="WarehouseIds"]').prop('disabled', false);
                }
            }

            $('#RoleId').change(updateWarehouseCheckboxes);
            $('input[name="WarehouseIds"]').change(updateWarehouseCheckboxes);

            // Initial run on load
            updateWarehouseCheckboxes();
        });
    </script>
}
