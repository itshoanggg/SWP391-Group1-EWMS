@model EWMS.ViewModels.WarehouseDetailsViewModel

@{
    ViewData["Title"] = Model.WarehouseName;
    Layout = "~/Views/Shared/_LayoutWarehouseManager.cshtml";
}

<div class="breadcrumb">
    <a asp-action="Index">Warehouses</a>
    <span class="sep">&gt;</span>
    <span>@Model.WarehouseName</span>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="detail-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:nowrap;">
    <div style="flex:1;">
        <div class="detail-id">@Model.WarehouseCode - Prefix: @Model.Prefix-</div>
        <div class="detail-name">@Model.WarehouseName</div>
        <div class="detail-sub">@Model.Address</div>
        <div class="detail-chips">
            <span class="chip">@Model.LocationCount locations</span>
            <span class="chip">@Model.TotalUsed / @Model.TotalCapacity units</span>
            @if (Model.CreatedAt.HasValue)
            {
                <span class="chip">Created: @Model.CreatedAt.Value.ToString("dd/MM/yyyy")</span>
            }
        </div>
    </div>
    <div style="display:flex;gap:8px;flex-shrink:0;">
        <a asp-action="Edit" asp-route-id="@Model.WarehouseId" class="btn btn-outline-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <button type="button" class="btn btn-primary" onclick="openAddLocationModal(@Model.WarehouseId)">
            <i class="bi bi-plus-circle"></i> Add Location
        </button>
    </div>
</div>

<div class="info-grid">
    <div class="info-block">
        <div class="ib-label">Total Locations</div>
        <div class="ib-val">@Model.LocationCount</div>
    </div>
    <div class="info-block">
        <div class="ib-label">Total Capacity</div>
        <div class="ib-val">@Model.TotalCapacity units</div>
    </div>
    <div class="info-block">
        <div class="ib-label">Currently Used</div>
        <div class="ib-val">@Model.TotalUsed units</div>
        <div class="ib-sub">@Model.UsagePercentage% capacity</div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="mb-0">Locations</h3>
        <button type="button" class="btn btn-primary btn-sm" onclick="openAddLocationModal(@Model.WarehouseId)">
            <i class="bi bi-plus-circle"></i> Add Location
        </button>
    </div>
    <div class="table-container">
        @if (Model.Locations.Any())
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Rack</th>
                        <th>Capacity</th>
                        <th>Used</th>
                        <th>Usage</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var location in Model.Locations)
                    {
                        var pct = location.UsagePercentage;
                        var badgeClass = pct >= 85 ? "badge-crit" : pct >= 60 ? "badge-warn" : "badge-ok";
                        var fillClass = pct >= 85 ? "crit" : pct >= 60 ? "warn" : "";

                        <tr>
                            <td class="td-mono">
                                <a asp-action="LocationDetails" asp-route-id="@location.LocationId" style="text-decoration:none;color:var(--navy-mid);font-weight:600;">
                                    @location.LocationCode
                                </a>
                            </td>
                            <td>@location.LocationName</td>
                            <td>
                                <span style="background:#e8f0f8;color:var(--navy-dark);padding:2px 8px;border-radius:6px;font-size:0.75rem;font-weight:700;">
                                    @location.Rack
                                </span>
                            </td>
                            <td>@location.Capacity</td>
                            <td>@location.Used</td>
                            <td>
                                <span class="badge @badgeClass">@pct%</span>
                                <div class="prog-wrap">
                                    <div class="prog-fill @fillClass" style="width:@pct%"></div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="openEditLocationModal(@location.LocationId, '@location.LocationCode', '@location.LocationName', '@location.Rack', @location.Capacity, @location.Used)">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button type="button" class="btn btn-danger-soft btn-sm" onclick="showDeleteModal(@location.LocationId, '@location.LocationCode', @Model.WarehouseId)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-3 mb-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Details" asp-route-id="@Model.WarehouseId" asp-route-page="@(Model.Page - 1)">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.WarehouseId" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Details" asp-route-id="@Model.WarehouseId" asp-route-page="@(Model.Page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="empty">
                <div class="empty-icon">
                    <i class="bi bi-geo-alt" style="font-size: 2.5rem;"></i>
                </div>
                <p>No locations yet.</p>
                <button type="button" class="btn btn-primary mt-2" onclick="openAddLocationModal(@Model.WarehouseId)">
                    <i class="bi bi-plus-circle"></i> Add First Location
                </button>
            </div>
        }
    </div>
</div>

<!-- Add Location Modal -->
<div class="modal fade" id="addLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateLocation" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="WarehouseId" id="modalWarehouseId" value="@Model.WarehouseId" />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label">
                                    Location Code <span class="text-danger">*</span>
                                    <small class="text-muted">- prefix auto-filled</small>
                                </label>
                                <div style="display:flex;">
                                    <span id="detailsPrefixSpan" style="background:#e3f2fd;border:1px solid var(--blue);border-right:none;
                                        border-radius:6px 0 0 6px;padding:10px;font-family:'Courier New',monospace;
                                        font-size:0.9rem;color:var(--navy);font-weight:700;white-space:nowrap;min-width:52px;text-align:center;">@Model.Prefix-</span>
                                    <input type="text" class="form-control" id="detailsSuffixInput" name="LocationCode" required maxlength="50" placeholder="A1-01"
                                        style="border-radius:0 6px 6px 0;border-left:none;font-family:'Courier New',monospace;" />
                                </div>
                                <div class="form-hint" id="detailsPreviewHint" style="color:var(--navy);font-weight:600;font-family:'Courier New',monospace;min-height:16px;margin-top:4px;"></div>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label for="detailsRackInput" class="form-label">
                                    Rack <span class="text-danger">*</span>
                                    <small class="text-muted">- auto-filled</small>
                                </label>
                                <input type="text" class="form-control auto-filled" id="detailsRackInput" name="Rack" required maxlength="20" placeholder="A1" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label for="detailsNameInput" class="form-label">
                                    Location Name
                                    <small class="text-muted">- auto-filled</small>
                                </label>
                                <input type="text" class="form-control auto-filled" id="detailsNameInput" name="LocationName" maxlength="100" placeholder="Rack A1 Slot 01" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label for="detailsCapacityInput" class="form-label">
                                    Capacity (units) <span class="text-danger">*</span>
                                </label>
                                <input type="number" class="form-control" id="detailsCapacityInput" name="Capacity" required min="1" placeholder="200" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Location</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Location Modal -->
<div class="modal fade" id="editLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditLocation" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="LocationId" id="editLocationId" />
                <input type="hidden" name="WarehouseId" value="@Model.WarehouseId" />
                <input type="hidden" name="CurrentUsed" id="editCurrentUsed" />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label for="editLocationCode" class="form-label">
                                    Location Code <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="editLocationCode" name="LocationCode" required maxlength="50" style="font-family:'Courier New',monospace;" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label for="editRack" class="form-label">
                                    Rack <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="editRack" name="Rack" required maxlength="20" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="editLocationName" class="form-label">Location Name</label>
                        <input type="text" class="form-control" id="editLocationName" name="LocationName" maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label for="editCapacity" class="form-label">
                            Capacity (units) <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control" id="editCapacity" name="Capacity" required min="1" />
                        <div class="form-hint" id="editUsedHint"></div>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-danger" onclick="showDeleteModalFromEdit()">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete location <strong id="deleteLocationCode"></strong>?</p>
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-info-circle"></i> <strong>Note:</strong> Cannot delete locations with inventory!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash"></i> Delete Location
                </button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnToWarehouse" value="@Model.WarehouseId" />
</form>

@section Styles {
    <link rel="stylesheet" href="~/css/Warehouse/warehouse.css" />
}

@section Scripts {
    <script>
        let detailsNameEdited = false;
        let detailsRackEdited = false;

        function openAddLocationModal(warehouseId) {
            // Clear previous data and reset flags
            document.getElementById('modalWarehouseId').value = warehouseId;
            document.getElementById('detailsSuffixInput').value = '';
            document.getElementById('detailsRackInput').value = '';
            document.getElementById('detailsNameInput').value = '';
            document.getElementById('detailsCapacityInput').value = '';
            document.getElementById('detailsPreviewHint').textContent = '';
            detailsNameEdited = false;
            detailsRackEdited = false;
            
            var modal = new bootstrap.Modal(document.getElementById('addLocationModal'));
            modal.show();
        }

        // Auto-fill location details from suffix
        document.getElementById('detailsSuffixInput')?.addEventListener('input', function() {
            const suffix = this.value.trim();
            const prefix = document.getElementById('detailsPrefixSpan').textContent;
            const previewHint = document.getElementById('detailsPreviewHint');
            const rackInput = document.getElementById('detailsRackInput');
            const nameInput = document.getElementById('detailsNameInput');

            // Update full code in input name attribute
            this.setAttribute('name', 'LocationCode');
            this.value = prefix + suffix;

            // Update preview
            previewHint.textContent = suffix ? `→ ${prefix}${suffix}` : '';

            // Auto-fill rack and name
            const parts = suffix.split('-');
            const rack = parts[0] || '';
            const slot = parts[1] || '';

            if (!detailsRackEdited && rack) {
                rackInput.value = rack;
            }

            if (!detailsNameEdited && rack && slot) {
                nameInput.value = `Rack ${rack} Slot ${slot}`;
            }

            // Reset to just suffix for clean display
            this.value = suffix;
        });

        document.getElementById('detailsNameInput')?.addEventListener('input', function() {
            detailsNameEdited = true;
        });

        document.getElementById('detailsRackInput')?.addEventListener('input', function() {
            detailsRackEdited = true;
        });

        // Before form submit, prepend prefix to location code
        document.querySelector('#addLocationModal form')?.addEventListener('submit', function(e) {
            const suffixInput = document.getElementById('detailsSuffixInput');
            const prefix = document.getElementById('detailsPrefixSpan').textContent;
            suffixInput.value = prefix + suffixInput.value.trim();
        });

        // Edit Location Modal
        function openEditLocationModal(locationId, locationCode, locationName, rack, capacity, currentUsed) {
            document.getElementById('editLocationId').value = locationId;
            document.getElementById('editLocationCode').value = locationCode;
            document.getElementById('editLocationName').value = locationName || '';
            document.getElementById('editRack').value = rack || '';
            document.getElementById('editCapacity').value = capacity;
            document.getElementById('editCurrentUsed').value = currentUsed;
            document.getElementById('editUsedHint').textContent = 'Currently using ' + currentUsed + ' units. Capacity cannot be less than this.';
            
            var modal = new bootstrap.Modal(document.getElementById('editLocationModal'));
            modal.show();
        }

        let currentDeleteId = null;
        let currentDeleteCode = null;

        function showDeleteModal(locationId, locationCode, warehouseId) {
            currentDeleteId = locationId;
            currentDeleteCode = locationCode;
            document.getElementById('deleteLocationCode').textContent = locationCode;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        function showDeleteModalFromEdit() {
            // Close edit modal first
            var editModal = bootstrap.Modal.getInstance(document.getElementById('editLocationModal'));
            if (editModal) {
                editModal.hide();
            }
            
            // Show delete modal with current location
            const locationId = document.getElementById('editLocationId').value;
            const locationCode = document.getElementById('editLocationCode').value;
            showDeleteModal(locationId, locationCode, @Model.WarehouseId);
        }

        document.getElementById('confirmDeleteBtn')?.addEventListener('click', function() {
            if (currentDeleteId) {
                var form = document.getElementById('deleteForm');
                form.action = '/Warehouse/DeleteLocation/' + currentDeleteId;
                form.submit();
            }
        });
    </script>
}
