@model EWMS.ViewModels.EditWarehouseViewModel

@{
    ViewData["Title"] = "Edit Warehouse";
    Layout = "~/Views/Shared/_LayoutWarehouseManager.cshtml";
}

<div class="breadcrumb">
    <a asp-action="Index">Warehouses</a>
    <span class="sep">&gt;</span>
    <a asp-action="Details" asp-route-id="@Model.WarehouseId">Details</a>
    <span class="sep">&gt;</span>
    <span>Edit</span>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="mb-0">Edit Warehouse Information</h3>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="WarehouseId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="WarehouseName" class="form-label">
                    Warehouse Name <span class="req">*</span>
                </label>
                <input asp-for="WarehouseName" class="form-control" />
                <span asp-validation-for="WarehouseName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label">
                    Address <span class="req">*</span>
                </label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Prefix" class="form-label">
                    Warehouse Prefix <small class="text-muted">(auto-generated from name)</small>
                </label>
                <input asp-for="Prefix" class="form-control" readonly style="font-family:'Courier New',monospace;text-transform:uppercase;background-color:#f8f9fa;" />
                <div class="form-hint">This prefix is automatically generated and used for location codes.</div>
            </div>

            <hr class="my-4" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.WarehouseId" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Warehouse/warehouse.css" />
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Auto-update prefix when warehouse name changes
        document.getElementById('WarehouseName').addEventListener('input', function() {
            var words = this.value.trim().split(/\s+/);
            var prefix = '';
            
            if (words.length >= 2) {
                prefix = (words[0][0] || '') + (words[1][0] || '');
            } else if (words.length === 1 && words[0].length >= 3) {
                prefix = words[0].substring(0, 3);
            } else if (words.length === 1) {
                prefix = words[0];
            }
            
            document.getElementById('Prefix').value = prefix.toUpperCase();
        });
    </script>
}
