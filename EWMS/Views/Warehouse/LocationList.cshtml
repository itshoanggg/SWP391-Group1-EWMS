@model EWMS.ViewModels.LocationListViewModel

@{
    ViewData["Title"] = "Location Management";
    Layout = "~/Views/Shared/_LayoutWarehouseManager.cshtml";
}

<div class="page-header">
    <h1>Locations</h1>
    <p>Manage storage locations in warehouses</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <form asp-action="LocationList" method="get" class="row g-2">
            <div class="col-md-3">
                <div class="search-wrap">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" value="@Model.SearchQuery" placeholder="Search code, name..." />
                </div>
            </div>
            <div class="col-md-3">
                <select name="warehouseId" class="form-select">
                    <option value="">All Warehouses</option>
                    @foreach (var wh in Model.Warehouses)
                    {
                        <option value="@wh.WarehouseId" selected="@(Model.FilterWarehouseId == wh.WarehouseId ? "selected" : null)">
                            @wh.WarehouseName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-funnel"></i> Filter
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || Model.FilterWarehouseId.HasValue)
                {
                    <a asp-action="LocationList" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Clear Filter
                    </a>
                }
            </div>
            <div class="col-md-auto ms-auto">
                <button type="button" class="btn btn-primary" onclick="openAddLocationModal(null)">
                    <i class="bi bi-plus-circle"></i> Add Location
                </button>
            </div>
        </form>
    </div>

    <div class="table-container">
        @if (Model.Locations.Any())
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Warehouse</th>
                        <th>Rack</th>
                        <th>Capacity</th>
                        <th>Used</th>
                        <th>Usage</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var location in Model.Locations)
                    {
                        var pct = location.UsagePercentage;
                        var badgeClass = pct >= 85 ? "badge-crit" : pct >= 60 ? "badge-warn" : "badge-ok";

                        <tr>
                            <td class="td-mono">
                                <a asp-action="LocationDetails" asp-route-id="@location.LocationId" style="text-decoration:none;color:var(--navy-mid);font-weight:600;">
                                    @location.LocationCode
                                </a>
                            </td>
                            <td>@location.LocationName</td>
                            <td style="font-size:0.82rem;color:var(--navy-mid);font-weight:600;">@location.WarehouseName</td>
                            <td>
                                <span style="background:#e8f0f8;color:var(--navy-dark);padding:2px 8px;border-radius:6px;font-size:0.75rem;font-weight:700;">
                                    @location.Rack
                                </span>
                            </td>
                            <td>@location.Capacity</td>
                            <td>@location.Used</td>
                            <td>
                                <span class="badge @badgeClass">@pct%</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="openEditLocationModal(@location.LocationId, '@location.LocationCode', '@location.LocationName', '@location.Rack', @location.Capacity, @location.Used, @location.WarehouseId)">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button type="button" class="btn btn-danger-soft btn-sm" onclick="showDeleteModal(@location.LocationId, '@location.LocationCode', null)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-3 mb-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="LocationList" asp-route-search="@Model.SearchQuery" 
                               asp-route-warehouseId="@Model.FilterWarehouseId" asp-route-page="@(Model.Page - 1)">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="LocationList" asp-route-search="@Model.SearchQuery" 
                                   asp-route-warehouseId="@Model.FilterWarehouseId" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="LocationList" asp-route-search="@Model.SearchQuery" 
                               asp-route-warehouseId="@Model.FilterWarehouseId" asp-route-page="@(Model.Page + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="empty">
                <div class="empty-icon">
                    <i class="bi bi-geo-alt" style="font-size: 2.5rem;"></i>
                </div>
                <p>No locations found.</p>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || Model.FilterWarehouseId.HasValue)
                {
                    <a asp-action="LocationList" class="btn btn-outline-primary mt-2">Clear Filter</a>
                }
            </div>
        }
    </div>
</div>

<!-- Add Location Modal -->
<div class="modal fade" id="addLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateLocation" method="post" id="addLocationListForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="listWarehouseSelect" class="form-label">
                            Warehouse <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="listWarehouseSelect" name="WarehouseId" required>
                            <option value="">-- Select Warehouse --</option>
                            @foreach (var wh in Model.Warehouses)
                            {
                                <option value="@wh.WarehouseId" data-prefix="@wh.WarehouseName.Split(' ').Take(2).Select(w => w.Substring(0, 1)).Aggregate((a, b) => a + b).ToUpper()">@wh.WarehouseName</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label">
                                    Location Code <span class="text-danger">*</span>
                                    <small class="text-muted">- prefix auto-filled</small>
                                </label>
                                <div style="display:flex;">
                                    <span id="listPrefixSpan" style="background:#e3f2fd;border:1px solid var(--blue);border-right:none;
                                        border-radius:6px 0 0 6px;padding:10px;font-family:'Courier New',monospace;
                                        font-size:0.9rem;color:var(--navy);font-weight:700;white-space:nowrap;min-width:52px;text-align:center;">??-</span>
                                    <input type="text" class="form-control" id="listSuffixInput" name="LocationCode" required maxlength="50" placeholder="A1-01"
                                        style="border-radius:0 6px 6px 0;border-left:none;font-family:'Courier New',monospace;" />
                                </div>
                                <div class="form-hint" id="listPreviewHint" style="color:var(--navy);font-weight:600;font-family:'Courier New',monospace;min-height:16px;margin-top:4px;"></div>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label for="listRackInput" class="form-label">
                                    Rack <span class="text-danger">*</span>
                                    <small class="text-muted">- auto-filled</small>
                                </label>
                                <input type="text" class="form-control auto-filled" id="listRackInput" name="Rack" required maxlength="20" placeholder="A1" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label for="listNameInput" class="form-label">
                                    Location Name
                                    <small class="text-muted">- auto-filled</small>
                                </label>
                                <input type="text" class="form-control auto-filled" id="listNameInput" name="LocationName" maxlength="100" placeholder="Rack A1 Slot 01" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label for="listCapacityInput" class="form-label">
                                    Capacity (units) <span class="text-danger">*</span>
                                </label>
                                <input type="number" class="form-control" id="listCapacityInput" name="Capacity" required min="1" placeholder="200" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Location</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Location Modal -->
<div class="modal fade" id="editLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditLocation" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="LocationId" id="editLocationId" />
                <input type="hidden" name="WarehouseId" id="editWarehouseId" />
                <input type="hidden" name="CurrentUsed" id="editCurrentUsed" />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label for="editLocationCode" class="form-label">
                                    Location Code <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="editLocationCode" name="LocationCode" required maxlength="50" style="font-family:'Courier New',monospace;" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label for="editRack" class="form-label">
                                    Rack <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="editRack" name="Rack" required maxlength="20" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="editLocationName" class="form-label">Location Name</label>
                        <input type="text" class="form-control" id="editLocationName" name="LocationName" maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label for="editCapacity" class="form-label">
                            Capacity (units) <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control" id="editCapacity" name="Capacity" required min="1" />
                        <div class="form-hint" id="editUsedHint"></div>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-danger" onclick="showDeleteModalFromEdit()">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete location <strong id="deleteLocationCode"></strong>?</p>
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-info-circle"></i> <strong>Note:</strong> Cannot delete locations with inventory!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash"></i> Delete Location
                </button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Styles {
    <link rel="stylesheet" href="~/css/Warehouse/warehouse.css" />
}

@section Scripts {
    <script>
        let listNameEdited = false;
        let listRackEdited = false;

        function openAddLocationModal(warehouseId) {
            // Clear previous data
            document.getElementById('listWarehouseSelect').value = warehouseId || '';
            document.getElementById('listSuffixInput').value = '';
            document.getElementById('listRackInput').value = '';
            document.getElementById('listNameInput').value = '';
            document.getElementById('listCapacityInput').value = '';
            document.getElementById('listPreviewHint').textContent = '';
            document.getElementById('listPrefixSpan').textContent = '??-';
            listNameEdited = false;
            listRackEdited = false;
            
            // If warehouse preselected, fetch prefix
            if (warehouseId) {
                onListWarehouseChange();
            }
            
            var modal = new bootstrap.Modal(document.getElementById('addLocationModal'));
            modal.show();
        }

        // When warehouse changes, update prefix
        document.getElementById('listWarehouseSelect')?.addEventListener('change', onListWarehouseChange);

        async function onListWarehouseChange() {
            const select = document.getElementById('listWarehouseSelect');
            const warehouseId = select.value;
            const prefixSpan = document.getElementById('listPrefixSpan');
            
            if (!warehouseId) {
                prefixSpan.textContent = '??-';
                return;
            }

            try {
                const response = await fetch(`/Warehouse/GetWarehousePrefix?warehouseId=${warehouseId}`);
                const data = await response.json();
                prefixSpan.textContent = (data.prefix || '??') + '-';
            } catch (error) {
                console.error('Error fetching prefix:', error);
                // Fallback to data attribute
                const option = select.options[select.selectedIndex];
                const prefix = option.getAttribute('data-prefix') || '??';
                prefixSpan.textContent = prefix + '-';
            }
        }

        // Auto-fill location details from suffix
        document.getElementById('listSuffixInput')?.addEventListener('input', function() {
            const suffix = this.value.trim();
            const prefix = document.getElementById('listPrefixSpan').textContent;
            const previewHint = document.getElementById('listPreviewHint');
            const rackInput = document.getElementById('listRackInput');
            const nameInput = document.getElementById('listNameInput');

            // Update preview
            previewHint.textContent = suffix ? `→ ${prefix}${suffix}` : '';

            // Auto-fill rack and name
            const parts = suffix.split('-');
            const rack = parts[0] || '';
            const slot = parts[1] || '';

            if (!listRackEdited && rack) {
                rackInput.value = rack;
            }

            if (!listNameEdited && rack && slot) {
                nameInput.value = `Rack ${rack} Slot ${slot}`;
            }
        });

        document.getElementById('listNameInput')?.addEventListener('input', function() {
            listNameEdited = true;
        });

        document.getElementById('listRackInput')?.addEventListener('input', function() {
            listRackEdited = true;
        });

        // Before form submit, prepend prefix to location code
        document.getElementById('addLocationListForm')?.addEventListener('submit', function(e) {
            const suffixInput = document.getElementById('listSuffixInput');
            const prefix = document.getElementById('listPrefixSpan').textContent;
            suffixInput.value = prefix + suffixInput.value.trim();
        });

        // Edit Location Modal
        function openEditLocationModal(locationId, locationCode, locationName, rack, capacity, currentUsed, warehouseId) {
            document.getElementById('editLocationId').value = locationId;
            document.getElementById('editWarehouseId').value = warehouseId;
            document.getElementById('editLocationCode').value = locationCode;
            document.getElementById('editLocationName').value = locationName || '';
            document.getElementById('editRack').value = rack || '';
            document.getElementById('editCapacity').value = capacity;
            document.getElementById('editCurrentUsed').value = currentUsed;
            document.getElementById('editUsedHint').textContent = 'Currently using ' + currentUsed + ' units. Capacity cannot be less than this.';
            
            var modal = new bootstrap.Modal(document.getElementById('editLocationModal'));
            modal.show();
        }

        let currentDeleteId = null;

        function showDeleteModal(locationId, locationCode, warehouseId) {
            currentDeleteId = locationId;
            document.getElementById('deleteLocationCode').textContent = locationCode;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        function showDeleteModalFromEdit() {
            // Close edit modal first
            var editModal = bootstrap.Modal.getInstance(document.getElementById('editLocationModal'));
            if (editModal) {
                editModal.hide();
            }
            
            // Show delete modal with current location
            const locationId = document.getElementById('editLocationId').value;
            const locationCode = document.getElementById('editLocationCode').value;
            showDeleteModal(locationId, locationCode, null);
        }

        document.getElementById('confirmDeleteBtn')?.addEventListener('click', function() {
            if (currentDeleteId) {
                var form = document.getElementById('deleteForm');
                form.action = '/Warehouse/DeleteLocation/' + currentDeleteId;
                form.submit();
            }
        });
    </script>
}
